# Shared with Django backend — must match config/settings.py JWT_SIGNING_KEY
JWT_SIGNING_KEY=unsafe-local-jwt-signing-key-for-development-only

# Comma-separated allowed origins for CSRF Origin/Referer check
# Defaults to the localhost dev pair when unset or empty
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,https://mozpay.co.mz

# Django backend URL (used by BFF +server.ts proxy routes)
# In dev, defaults to http://localhost:8000
# BACKEND_URL=http://localhost:8000
